{
  "name": "@citestyle/styles",
  "version": "1.0.0",
  "description": "Pre-compiled popular CSL styles (~3-5KB each)",
  "author": "Uniweb",
  "homepage": "https://github.com/uniweb/csl/tree/main/packages/styles",
  "repository": {
    "type": "git",
    "url": "https://github.com/uniweb/csl.git",
    "directory": "packages/styles"
  },
  "keywords": [
    "csl",
    "citation",
    "styles",
    "apa",
    "mla",
    "chicago",
    "ieee",
    "vancouver",
    "bibliography"
  ],
  "type": "module",
  "exports": {
    "./apa": "./apa.js",
    "./mla": "./mla.js",
    "./chicago-author-date": "./chicago-author-date.js",
    "./ieee": "./ieee.js",
    "./vancouver": "./vancouver.js",
    "./harvard": "./harvard.js",
    "./ama": "./ama.js",
    "./nature": "./nature.js",
    "./science": "./science.js"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./types.d.ts"
      ]
    }
  },
  "files": [
    "apa.js",
    "mla.js",
    "chicago-author-date.js",
    "ieee.js",
    "vancouver.js",
    "harvard.js",
    "ama.js",
    "nature.js",
    "science.js",
    "types.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js",
    "prepack": "node build.js"
  },
  "dependencies": {
    "@citestyle/core": "workspace:*"
  },
  "license": "MIT"
}
